# PromptCTF-Env Environment Configuration

# Weights & Biases
WANDB_PROJECT=promptctf-env
WANDB_ENTITY=
WANDB_API_KEY=

# Model Configuration
TRANSFORMERS_CACHE=./models
HF_HOME=./models

# GPU Configuration
CUDA_VISIBLE_DEVICES=0

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=false

# UI Configuration
UI_HOST=0.0.0.0
UI_PORT=7860
UI_SHARE=false

# Logging
LOG_LEVEL=INFO

# Model Names (can be overridden at runtime)
DEFENDER_MODEL=Qwen/Qwen2.5-7B
ATTACKER_MODEL=Qwen/Qwen2.5-7B
